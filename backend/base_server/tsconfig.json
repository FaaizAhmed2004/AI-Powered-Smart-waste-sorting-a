{
  "compilerOptions": {
    "target": "es2016",
    "module": "commonjs",
    "rootDir": "./src",
    "outDir": "./dist",

    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictPropertyInitialization": true,
    "alwaysStrict": true,

    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,

    "skipLibCheck": true,

    // ✅ IMPORTANT FIX (production safe)
    "types": ["node"]
  },

  // ✅ CRITICAL: exclude tests from build
  "exclude": [
    "src/__tests__",
    "**/*.spec.ts",
    "**/*.test.ts"
  ]}