# Backend API Configuration Template
# Copy this file to .env and update the values for your deployment environment

# AI Model API (YOLO waste detection)
VITE_AI_API_URL=http://localhost:8000

# REST API (User, auth, gamification endpoints)
VITE_REST_API_URL=http://localhost:3000/v1

# Note: Environment variables must be prefixed with VITE_ to be accessible in Vite frontend
