{
  "version": 2,
  "builds": [
    {
      "src": "ai-waste-sort/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "env": {
    "VITE_API_URL": "https://your-backend-url.com/v1",
    "VITE_AI_API_URL": "https://your-ai-server-url.com",
    "VITE_GOOGLE_MAPS_API_KEY": "your-google-maps-api-key"
  }
}